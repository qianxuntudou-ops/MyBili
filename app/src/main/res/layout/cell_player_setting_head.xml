<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:paddingTop="@dimen/px45"
    android:paddingBottom="@dimen/px30"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/px40"
    android:paddingEnd="@dimen/px40">
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/px40"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setting"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/px25"
        android:textColor="?android:attr/textColorSecondary"
        android:id="@+id/subTextView"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/more_quality_tip"/>
</androidx.appcompat.widget.LinearLayoutCompat>
