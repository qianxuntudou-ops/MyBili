<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColor">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/button_back"
        android:layout_width="@dimen/px100"
        android:layout_height="@dimen/px100"
        android:layout_marginStart="@dimen/px20"
        android:layout_marginTop="@dimen/px25"
        android:background="@drawable/cell_background"
        android:clickable="true"
        android:focusable="true"
        android:padding="@dimen/px30"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_back"
        app:tint="?android:attr/textColorPrimary" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/px24"
        android:layout_marginEnd="@dimen/px40"
        android:text="@string/collection"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="@dimen/px40"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/button_back"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/button_back"
        app:layout_constraintTop_toTopOf="@+id/button_back" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewFavorite"
        android:focusable="false"
        android:descendantFocusability="afterDescendants"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="@dimen/px20"
        android:paddingTop="@dimen/px20"
        android:paddingEnd="@dimen/px20"
        android:paddingBottom="@dimen/px50"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button_back" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/empty"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="@dimen/px30"
        android:visibility="gone"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:layout_constraintBottom_toBottomOf="@+id/recyclerViewFavorite"
        app:layout_constraintEnd_toEndOf="@+id/recyclerViewFavorite"
        app:layout_constraintStart_toStartOf="@+id/recyclerViewFavorite"
        app:layout_constraintTop_toTopOf="@+id/recyclerViewFavorite" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="@dimen/px120"
        android:layout_height="@dimen/px120"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/recyclerViewFavorite"
        app:layout_constraintEnd_toEndOf="@+id/recyclerViewFavorite"
        app:layout_constraintStart_toStartOf="@+id/recyclerViewFavorite"
        app:layout_constraintTop_toTopOf="@+id/recyclerViewFavorite" />
</androidx.constraintlayout.widget.ConstraintLayout>
