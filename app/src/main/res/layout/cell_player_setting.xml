<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/click_view"
    android:background="?attr/selectableItemBackground"
    android:paddingTop="@dimen/px20"
    android:paddingBottom="@dimen/px20"
    android:focusable="true"
    android:clipChildren="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/imageView"
        android:layout_width="@dimen/px50"
        android:layout_height="@dimen/px50"
        android:layout_marginStart="@dimen/px30"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_video_play_count"
        app:tint="?android:attr/textColorPrimary"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:orientation="vertical"
        android:id="@+id/view_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/px30"
        android:paddingEnd="@dimen/px30"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/icon_more"
        app:layout_constraintStart_toEndOf="@+id/imageView"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="@dimen/px35"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:id="@+id/text_view_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/video_quality"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="@dimen/px31"
            android:textColor="?android:attr/textColorSecondary"
            android:id="@+id/text_view_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1080P"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/icon_more"
        android:layout_width="@dimen/px35"
        android:layout_height="@dimen/px35"
        android:layout_marginEnd="@dimen/px30"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_arrow_right"
        app:tint="?android:attr/textColorPrimary"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/icon_check"
        android:visibility="gone"
        android:layout_width="@dimen/px40"
        android:layout_height="@dimen/px40"
        android:layout_marginEnd="@dimen/px30"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_check"
        app:tint="?android:attr/textColorPrimary"/>
</androidx.constraintlayout.widget.ConstraintLayout>
