<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/px1200"
    android:layout_height="@dimen/px615"
    android:background="@drawable/dialog_background"
    android:clickable="true"
    android:focusable="true"
    android:paddingBottom="@dimen/px20">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/imageView"
        android:layout_width="@dimen/px400"
        android:layout_height="@dimen/px225"
        android:layout_marginStart="@dimen/px20"
        android:layout_marginTop="@dimen/px20"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/default_video" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="@dimen/px740"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/px20"
        android:layout_marginEnd="@dimen/px20"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/imageView"
        app:layout_constraintTop_toTopOf="@+id/imageView">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/text_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingMultiplier="1.1"
                android:paddingBottom="@dimen/px10"
                android:paddingStart="@dimen/px5"
                android:paddingEnd="@dimen/px5"
                android:text="@string/choose_episode"
                android:textColor="@color/textColor"
                android:textSize="@dimen/px35"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/text_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingMultiplier="1.1"
                android:paddingBottom="@dimen/px20"
                android:paddingStart="@dimen/px5"
                android:paddingEnd="@dimen/px5"
                android:text="@string/choose_episode"
                android:textColor="@color/subTextColor"
                android:textSize="@dimen/px30" />
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.core.widget.NestedScrollView>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/button_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/px20"
        android:layout_marginEnd="@dimen/px20"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:paddingTop="@dimen/px20"
        android:paddingBottom="@dimen/px20"
        android:paddingStart="@dimen/px20"
        android:paddingEnd="@dimen/px20"
        android:text="@string/close"
        android:textColor="@color/red"
        android:textSize="@dimen/px25"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/scrollView" />
</androidx.constraintlayout.widget.ConstraintLayout>
