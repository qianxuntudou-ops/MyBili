<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:clickable="true"
    android:focusable="true"
    android:layout_width="@dimen/px550"
    android:layout_height="@dimen/px270">
    <androidx.appcompat.widget.LinearLayoutCompat
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_width="@dimen/px550"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/button_like"
            android:background="?attr/selectableItemBackground"
            android:padding="@dimen/px20"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.15"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.25">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/icon_like"
                android:layout_width="@dimen/px60"
                android:layout_height="@dimen/px60"
                app:srcCompat="@drawable/ic_like"
                app:tint="@color/textColor"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="@dimen/px30"
                android:textStyle="bold"
                android:textColor="@color/textColor"
                android:id="@+id/text_like"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/px20"
                android:text="@string/like"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/button_coin"
            android:background="?attr/selectableItemBackground"
            android:padding="@dimen/px20"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.25">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/icon_coin"
                android:layout_width="@dimen/px60"
                android:layout_height="@dimen/px60"
                app:srcCompat="@drawable/ic_coin"
                app:tint="@color/textColor"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="@dimen/px30"
                android:textStyle="bold"
                android:textColor="@color/textColor"
                android:id="@+id/text_coin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/px20"
                android:text="@string/give_coin"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/button_collection"
            android:background="?attr/selectableItemBackground"
            android:padding="@dimen/px20"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.85"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.25">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/icon_collection"
                android:layout_width="@dimen/px60"
                android:layout_height="@dimen/px60"
                app:srcCompat="@drawable/ic_favorite"
                app:tint="@color/textColor"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="@dimen/px30"
                android:textStyle="bold"
                android:textColor="@color/textColor"
                android:id="@+id/text_collection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/px20"
                android:text="@string/collection"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/px27"
        android:textStyle="bold"
        android:textColor="@color/pink"
        android:gravity="center"
        android:id="@+id/button_triple"
        android:background="?attr/selectableItemBackground"
        android:padding="@dimen/px15"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="@dimen/px550"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/px10"
        android:text="@string/triple_action"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.appcompat.widget.LinearLayoutCompat>
