<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="@dimen/px30">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/image_top"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="@+id/image_cover"
        app:layout_constraintDimensionRatio="h,1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <View
        android:background="@drawable/series_top_cover"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/image_top"
        app:layout_constraintEnd_toEndOf="@+id/image_top"
        app:layout_constraintStart_toStartOf="@+id/image_top"
        app:layout_constraintTop_toTopOf="@+id/image_top"/>
    <View
        android:background="@drawable/series_top_cover_2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/image_top"
        app:layout_constraintEnd_toEndOf="@+id/image_top"
        app:layout_constraintStart_toStartOf="@+id/image_top"
        app:layout_constraintTop_toTopOf="@+id/image_top"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/image_cover"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/px60"
        android:scaleType="centerCrop"
        android:contentDescription="Series Cover"
        android:layout_marginStart="@dimen/px130"
        android:elevation="10dp"
        app:layout_constraintDimensionRatio="h,3:4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.2"
        app:srcCompat="@drawable/default_video"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/text_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/px50"
        android:layout_marginEnd="@dimen/px100"
        android:layout_marginLeft="@dimen/px50"
        android:layout_marginRight="@dimen/px100"
        android:lineSpacingMultiplier="1.1"
        android:text="标题标题标题标题标题标题标题标题标题"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="@dimen/px40"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/image_cover"
        app:layout_constraintTop_toTopOf="@+id/image_cover" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/text_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/px15"
        android:lineSpacingMultiplier="1.1"
        android:text="标题标题标题标题标题标题标题标题标题"
        android:textColor="?attr/tabBarNormal"
        android:textSize="@dimen/px30"
        app:layout_constraintEnd_toEndOf="@+id/text_title"
        app:layout_constraintStart_toStartOf="@+id/text_title"
        app:layout_constraintTop_toBottomOf="@+id/text_title"
        app:layout_constraintVertical_bias="0.1" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/text_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/px15"
        android:text="标题标题标题标题标题标题标题标题标题"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="@dimen/px32"
        app:layout_constraintEnd_toEndOf="@+id/text_title"
        app:layout_constraintStart_toStartOf="@+id/text_title"
        app:layout_constraintTop_toBottomOf="@+id/text_subtitle" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/text_watch_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/px30"
        android:text="@string/last_watch_"
        android:textColor="?attr/tabBarNormal"
        android:textSize="@dimen/px25"
        app:layout_constraintStart_toStartOf="@+id/text_title"
        app:layout_constraintTop_toBottomOf="@+id/text_description" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button_continue_watch"
        android:layout_width="@dimen/px250"
        android:layout_height="@dimen/px80"
        android:layout_marginStart="@dimen/px49"
        android:layout_marginLeft="@dimen/px49"
        android:layout_marginTop="@dimen/px20"
        android:background="@drawable/button_common"
        android:text="@string/continue_watch"
        android:textSize="@dimen/px30"
        app:layout_constraintStart_toEndOf="@+id/image_cover"
        app:layout_constraintTop_toBottomOf="@+id/text_watch_info">

        <requestFocus />
    </androidx.appcompat.widget.AppCompatButton>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button_follow_series"
        android:layout_width="@dimen/px250"
        android:layout_height="@dimen/px80"
        android:layout_marginStart="@dimen/px30"
        android:layout_marginLeft="@dimen/px30"
        android:background="@drawable/button_common"
        android:text="@string/follow_series"
        android:textSize="@dimen/px30"
        app:layout_constraintBottom_toBottomOf="@+id/button_continue_watch"
        app:layout_constraintStart_toEndOf="@+id/button_continue_watch"
        app:layout_constraintTop_toTopOf="@+id/button_continue_watch" />
</androidx.constraintlayout.widget.ConstraintLayout>
