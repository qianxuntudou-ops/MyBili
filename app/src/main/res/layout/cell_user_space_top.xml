<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/image_top"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintDimensionRatio="h,6:1"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/series_top_cover"
        app:layout_constraintBottom_toBottomOf="@+id/image_top"
        app:layout_constraintEnd_toEndOf="@+id/image_top"
        app:layout_constraintStart_toStartOf="@+id/image_top"
        app:layout_constraintTop_toTopOf="@+id/image_top" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/image_avatar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/px130"
        android:layout_marginBottom="@dimen/px20"
        android:contentDescription="Avatar"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="h,1:1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_percent="0.1"
        app:srcCompat="@drawable/default_avatar" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/view_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/px50"
        android:layout_marginEnd="@dimen/px100"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@+id/image_avatar"
        app:layout_constraintStart_toEndOf="@+id/image_avatar"
        app:layout_constraintTop_toTopOf="@+id/image_avatar">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/text_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="@dimen/px40"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/text_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/px15"
            android:textColor="?attr/tabBarNormal"
            android:textSize="@dimen/px25" />
    </androidx.appcompat.widget.LinearLayoutCompat>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button_follow"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/px80"
        android:layout_marginStart="@dimen/px49"
        android:background="@drawable/button_common"
        android:text="@string/follow"
        android:textSize="@dimen/px30"
        app:layout_constraintBottom_toBottomOf="@+id/view_name"
        app:layout_constraintStart_toEndOf="@+id/view_name" />
</androidx.constraintlayout.widget.ConstraintLayout>
