<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="@dimen/px30">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/image_cover"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/px130"
        android:layout_marginTop="@dimen/px60"
        android:contentDescription="Series Cover"
        android:elevation="10dp"
        android:scaleType="centerCrop"
        app:layout_constraintDimensionRatio="h,16:9"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.35"
        app:srcCompat="@drawable/default_video" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/text_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/px50"
        android:layout_marginEnd="@dimen/px100"
        android:lineSpacingMultiplier="1.1"
        android:text="标题标题标题标题标题标题标题标题标题"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="@dimen/px40"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/image_cover"
        app:layout_constraintTop_toTopOf="@+id/image_cover" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/text_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/px15"
        android:lineSpacingMultiplier="1.1"
        android:text="标题标题标题标题标题标题标题标题标题"
        android:textColor="?attr/tabBarNormal"
        android:textSize="@dimen/px30"
        app:layout_constraintEnd_toEndOf="@+id/text_title"
        app:layout_constraintStart_toStartOf="@+id/text_title"
        app:layout_constraintTop_toBottomOf="@+id/text_title"
        app:layout_constraintVertical_bias="0.1" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/button_uploader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/px7"
        android:background="@drawable/cell_background"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:nextFocusRight="@+id/button_play"
        app:layout_constraintStart_toStartOf="@+id/image_cover"
        app:layout_constraintTop_toBottomOf="@+id/image_cover"
        app:layout_constraintVertical_bias="0.1">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/image_avatar"
            android:layout_width="@dimen/px70"
            android:layout_height="@dimen/px70"
            android:layout_marginStart="@dimen/px5"
            android:layout_marginTop="@dimen/px15"
            android:layout_marginBottom="@dimen/px15"
            app:srcCompat="@drawable/default_avatar" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/text_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/px15"
            android:layout_weight="1"
            android:ellipsize="marquee"
            android:singleLine="true"
            android:text="Title"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="@dimen/px30"
            android:textStyle="bold" />
    </androidx.appcompat.widget.LinearLayoutCompat>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/text_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/px15"
        android:text="标题标题标题标题标题标题标题标题标题"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="@dimen/px32"
        app:layout_constraintEnd_toEndOf="@+id/text_title"
        app:layout_constraintStart_toStartOf="@+id/text_title"
        app:layout_constraintTop_toBottomOf="@+id/text_subtitle" />

    <com.google.android.flexbox.FlexboxLayout
        android:id="@+id/view_flex_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/px30"
        android:layout_marginTop="@dimen/px25"
        android:descendantFocusability="afterDescendants"
        android:focusable="true"
        android:paddingStart="@dimen/px20"
        android:paddingEnd="@dimen/px20"
        android:paddingBottom="@dimen/px10"
        app:alignItems="flex_start"
        app:flexWrap="wrap"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/image_cover"
        app:layout_constraintTop_toBottomOf="@+id/text_description" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button_play"
        android:layout_width="@dimen/px180"
        android:layout_height="@dimen/px80"
        android:layout_marginStart="@dimen/px49"
        android:background="@drawable/button_common"
        android:nextFocusLeft="@+id/button_uploader"
        android:text="@string/watch"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="@dimen/px30"
        app:layout_constraintStart_toEndOf="@+id/image_cover"
        app:layout_constraintTop_toBottomOf="@+id/view_flex_layout">
        <requestFocus />
    </androidx.appcompat.widget.AppCompatButton>

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/button_like"
        android:layout_width="@dimen/px80"
        android:layout_height="@dimen/px80"
        android:layout_marginStart="@dimen/px30"
        android:background="@drawable/button_common"
        android:clickable="true"
        android:focusable="true"
        android:padding="@dimen/px20"
        app:layout_constraintBottom_toBottomOf="@+id/button_play"
        app:layout_constraintStart_toEndOf="@+id/button_play"
        app:layout_constraintTop_toTopOf="@+id/button_play"
        app:srcCompat="@drawable/ic_like"
        app:tint="?android:attr/textColorPrimary" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/button_coin"
        android:layout_width="@dimen/px80"
        android:layout_height="@dimen/px80"
        android:layout_marginStart="@dimen/px30"
        android:background="@drawable/button_common"
        android:clickable="true"
        android:focusable="true"
        android:padding="@dimen/px20"
        app:layout_constraintBottom_toBottomOf="@+id/button_like"
        app:layout_constraintStart_toEndOf="@+id/button_like"
        app:layout_constraintTop_toTopOf="@+id/button_like"
        app:srcCompat="@drawable/ic_coin"
        app:tint="?android:attr/textColorPrimary" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/button_favorite"
        android:layout_width="@dimen/px80"
        android:layout_height="@dimen/px80"
        android:layout_marginStart="@dimen/px30"
        android:background="@drawable/button_common"
        android:clickable="true"
        android:focusable="true"
        android:padding="@dimen/px20"
        app:layout_constraintBottom_toBottomOf="@+id/button_coin"
        app:layout_constraintStart_toEndOf="@+id/button_coin"
        app:layout_constraintTop_toTopOf="@+id/button_coin"
        app:srcCompat="@drawable/ic_favorite"
        app:tint="?android:attr/textColorPrimary" />
</androidx.constraintlayout.widget.ConstraintLayout>
