<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/click_view"
    android:background="@drawable/cell_background"
    android:paddingBottom="@dimen/px10"
    android:focusable="true"
    android:clickable="true"
    android:layout_width="@dimen/px400"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/imageView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/px10"
        android:layout_marginStart="@dimen/px10"
        android:layout_marginEnd="@dimen/px10"
        app:layout_constraintDimensionRatio="h,16:9"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/default_video"/>
    <View
        android:id="@+id/view_cover"
        android:background="@drawable/focus_background_round"
        android:layout_width="0dp"
        android:layout_height="@dimen/px70"
        app:layout_constraintBottom_toBottomOf="@+id/imageView"
        app:layout_constraintEnd_toEndOf="@+id/imageView"
        app:layout_constraintStart_toStartOf="@+id/imageView"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/icon_play"
        android:visibility="gone"
        android:layout_width="@dimen/px30"
        android:layout_height="@dimen/px30"
        android:layout_marginBottom="@dimen/px20"
        android:layout_marginEnd="@dimen/px18"
        app:layout_constraintBottom_toBottomOf="@+id/imageView"
        app:layout_constraintEnd_toEndOf="@+id/imageView"
        app:srcCompat="@drawable/ic_play"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/px22"
        android:textColor="@color/textColor"
        android:id="@+id/text_badge"
        android:background="@drawable/badge_background"
        android:paddingTop="@dimen/px3"
        android:paddingBottom="@dimen/px3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/badge"
        android:paddingStart="@dimen/px7"
        android:paddingEnd="@dimen/px7"
        app:layout_constraintEnd_toEndOf="@+id/imageView"
        app:layout_constraintTop_toTopOf="@+id/imageView"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/px35"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:ellipsize="end"
        android:id="@+id/text_position"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/px10"
        android:text="01"
        android:maxLines="1"
        android:shadowColor="@color/black"
        android:shadowDx="1.5"
        android:shadowDy="1.3"
        android:shadowRadius="1.6"
        android:layout_marginStart="@dimen/px20"
        android:layout_marginEnd="@dimen/px20"
        app:layout_constraintBottom_toBottomOf="@+id/imageView"
        app:layout_constraintEnd_toEndOf="@+id/imageView"
        app:layout_constraintStart_toStartOf="@+id/imageView"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/px30"
        android:textColor="?android:attr/textColorPrimary"
        android:id="@+id/text_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/px10"
        android:text="TitleTitleTitleTitleTitle"
        android:maxLines="2"
        app:layout_constraintEnd_toEndOf="@+id/imageView"
        app:layout_constraintStart_toStartOf="@+id/imageView"
        app:layout_constraintTop_toBottomOf="@+id/imageView"/>
</androidx.constraintlayout.widget.ConstraintLayout>
