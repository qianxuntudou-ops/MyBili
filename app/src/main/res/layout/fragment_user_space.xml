<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColor">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewVideos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:descendantFocusability="afterDescendants"
        android:focusable="false"
        android:paddingTop="0dp"
        android:paddingBottom="@dimen/px50"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="@dimen/px120"
        android:layout_height="@dimen/px120"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/recyclerViewVideos"
        app:layout_constraintEnd_toEndOf="@+id/recyclerViewVideos"
        app:layout_constraintStart_toStartOf="@+id/recyclerViewVideos"
        app:layout_constraintTop_toTopOf="@+id/recyclerViewVideos" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/button_back"
        android:layout_width="@dimen/px100"
        android:layout_height="@dimen/px100"
        android:layout_marginStart="@dimen/px20"
        android:layout_marginTop="@dimen/px25"
        android:background="@drawable/cell_background"
        android:clickable="true"
        android:elevation="@dimen/px10"
        android:focusable="true"
        android:padding="@dimen/px30"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_back"
        app:tint="?android:attr/textColorPrimary" />

</androidx.constraintlayout.widget.ConstraintLayout>
