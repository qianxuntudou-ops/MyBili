<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android" android:exitFadeDuration="@android:integer/config_shortAnimTime">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="?attr/colorPrimary"/>
            <corners android:radius="@dimen/px15"/>
            <stroke android:width="@dimen/px2" android:color="@color/colorAccent"/>
        </shape>
    </item>
    <item android:state_focused="true">
        <shape>
            <solid android:color="?attr/colorControlHighlight"/>
            <corners android:radius="@dimen/px15"/>
            <stroke android:width="@dimen/px2" android:color="@color/colorAccent"/>
        </shape>
    </item>
    <item android:state_selected="true">
        <shape>
            <solid android:color="?attr/fourthBackgroundColor"/>
            <corners android:radius="@dimen/px15"/>
            <stroke android:width="@dimen/px2" android:color="@color/colorAccent"/>
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@android:color/transparent"/>
            <corners android:radius="@dimen/px15"/>
            <stroke android:width="@dimen/px2" android:color="@android:color/white"/>
        </shape>
    </item>
</selector>
